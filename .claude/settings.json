{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-commit-check.sh\"",
            "timeout": 300,
            "statusMessage": "Running pre-commit checks (prettier, build, lint, test + 100% coverage)..."
          }
        ]
      }
    ]
  }
}
